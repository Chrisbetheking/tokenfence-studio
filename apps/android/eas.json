{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "preview-apk": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "cache": {
        "disabled": true
      },
      "env": {
        "EAS_BUILD_DISABLE_NPM_CACHE": "1",
        "EAS_BUILD_DISABLE_MAVEN_CACHE": "1"
      },
      "channel": "preview-apk"
    },
    "production-aab": {
      "android": {
        "buildType": "app-bundle"
      },
      "distribution": "store",
      "channel": "production-aab"
    },
    "ios-simulator": {
      "ios": {
        "simulator": true
      },
      "distribution": "internal",
      "channel": "ios-simulator"
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
